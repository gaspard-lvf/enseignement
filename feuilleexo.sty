  {\normalfont \large \bfseries}{\thesubsection}{1em}{}
\titleformat{\subsubsection}
  {\normalfont\large }{\thesubsubsection}{1em}{}

%%%STYLE DES ITEMIZE
\setitemize[1]{label=\textbullet}

%%%LEFTBAR (citation / passage mis en retrait, ex. démonstration à commenter)
\renewenvironment{leftbar}{%
  \def\FrameCommand{\hspace{0.5cm}\vrule width 0.4pt \hspace{0pt}}%
  \MakeFramed{\advance\hsize -\width\FrameRestore}}%
 {\endMakeFramed}

%%%TITRE DE LA FEUILLE
\newcommand{\montitre}[1]{
\begin{center}
\doublebox{
 \Large \scshape
 #1}
\end{center}
}

%%%CITATION / ÉPIGRAPHE (facultative, en tête de feuille)
\newcommand{\epigraphe}[4]{
\begin{minipage}{0.05\textwidth}
\hspace{1pt}
\end{minipage} \hfill
\begin{minipage}{0.9\textwidth}
\center
\small
\og #1 \fg{}
\flushright {\footnotesize \textsc{#2}, \textit{#3} (#4)}
\end{minipage}\\[\baselineskip]
}

%%%ENCADRÉ GÉNÉRIQUE
\newcommand{\cbox}[1]{\begin{tcolorbox}[lower separated=false, colback=white]
#1
\end{tcolorbox}}

%%%ENCADRÉ PRÉ-REQUIS (nouveauté)
%%% Usage : \begin{prerequis} ... \end{prerequis}
%%%         \begin{prerequis}[Rappels] ... \end{prerequis}  (titre personnalisé)
\newtcolorbox{prerequis}[1][Pré-requis]{
  colback=white, colframe=black,
  boxrule=0.6pt, arc=0pt,
  left=8pt, right=8pt, top=5pt, bottom=5pt,
  fonttitle=\bfseries\scshape, coltitle=black,
  colbacktitle=white,
  title=#1,
  before upper={\begin{multicols}{2}},
  after upper={\end{multicols}}
}

