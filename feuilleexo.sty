%%%ENVIRONNEMENT EXERCICE + SYMBOLE DE CLASSEMENT (nouveauté)
%%% Usage :
%%%   \begin{exo} ... \end{exo}                    exercice de base (•)
%%%   \begin{exo}[][appro] ... \end{exo}            approfondissement (▲)
%%%   \begin{exo}[][bac] ... \end{exo}              type Bac ("Bac")
%%%   \begin{exo}[Aire maximale][bac] ... \end{exo}  avec titre + type
%%%
%%% Le symbole est posé au fer gauche de la colonne courante (\llap), donc
%%% il reste visible aussi bien en 1 colonne qu'en 2 colonnes (multicols).

\newcounter{exo}

\newcommand{\@exoicone}[1]{%
  \ifstrequal{#1}{avance}{$\star$}{%
  \ifstrequal{#1}{appro}{\scalebox{0.75}{$\blacktriangle$}}{%
  \ifstrequal{#1}{bac}{\fbox{\footnotesize\textbf{Bac}}}{%
  \scalebox{1.15}{\textbullet}}}}%
}

\NewDocumentEnvironment{exo}{ O{} O{base} }{%
  \par\addvspace{10pt}\noindent
  \refstepcounter{exo}%
  \llap{\@exoicone{#2}\hspace{8pt}}%
  \textbf{\scshape Exercice~\theexo}\ifblank{#1}{}{ \textnormal{(#1)}}\textbf{.}~\ignorespaces
}{%
  \par\addvspace{4pt}%
}


%%% Pour la version prof/élève

\usepackage{etoolbox}

\newbool{prof}
\ifdefstring{\version}{prof}
  {\booltrue{prof}}
  {\boolfalse{prof}}

\newcommand{\prof}[1]{%
  \ifbool{prof}{#1}{}%
}

%%% Légende à placer sous le titre de la feuille, pour rappeler le code
\newcommand{\legendeicones}{%
