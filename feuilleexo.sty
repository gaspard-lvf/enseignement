%%% feuilleexo.sty
%%% Package pour la mise en forme des feuilles d'exercices de mathématiques.
%%% Basé sur le préambule fourni, allégé des éléments non utilisés / fragiles
%%% (packages sans dépendance claire, symboles de marge non démontrés, etc.)
%%%
%%% Nouveautés par rapport au préambule d'origine :
%%%   - \begin{prerequis}...\end{prerequis}  : encadré "Pré-requis" en tête de feuille
%%%   - \begin{exo}[Titre][type] : environnement d'exercice avec symbole de
%%%     classement ( • , petit triangle plein, "Bac" ) ancré dans la marge
%%%     GAUCHE DE LA COLONNE COURANTE (fonctionne donc en mode multicols,
%%%     contrairement à \marginpar/marginnote qui ne connaissent que la
%%%     marge de la page et disparaissent en 2e colonne).
%%%   - \legendeicones : rappel imprimable de la signification des 3 symboles
%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%

\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{feuilleexo}[2026/07/02 v1.0 Feuille d'exercices de maths]

